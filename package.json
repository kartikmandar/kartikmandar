{
  "name": "kartikmandar",
  "version": "2.0.0",
  "description": "Kartik Mandar - Personal portfolio and blog",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
